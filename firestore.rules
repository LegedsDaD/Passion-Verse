rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /roadmaps/{roadmapId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Per-user "bring your own API key" settings (Gemini / ElevenLabs).
    match /userSettings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // FCM tokens for scheduled push notifications. Owned by the user; a
    // privileged Cloud Function (using the Admin SDK) reads this collection
    // to target a specific user when a timetable session is due.
    match /userTokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
